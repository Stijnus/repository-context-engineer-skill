{
  // Example snippets only. Merge carefully into your real Claude Code settings.
  //
  // Optional: after Write/Edit/MultiEdit, refresh the project context pack if structure
  // may have changed. This is intentionally conservative — many teams prefer to run
  // the builder manually rather than on every file edit.
  //
  // The hook below prefers the V3 builder when present (query routing, import graph,
  // token counts) and falls back to V2 if V3 is not installed. If neither builder is
  // on disk the hook is a silent no-op.
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f .claude/skills/repository-context-engineer/scripts/build_context_pack_v3.py ]; then python .claude/skills/repository-context-engineer/scripts/build_context_pack_v3.py . >/dev/null 2>&1 || true; elif [ -f .claude/skills/repository-context-engineer/scripts/build_context_pack.py ]; then python .claude/skills/repository-context-engineer/scripts/build_context_pack.py . >/dev/null 2>&1 || true; fi"
          }
        ]
      }
    ]
  }
}
